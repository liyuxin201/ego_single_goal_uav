# Editor / IDE local settings
/.vscode/
/.idea/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp

# Nested Git metadata from copied packages/submodules
**/.git
