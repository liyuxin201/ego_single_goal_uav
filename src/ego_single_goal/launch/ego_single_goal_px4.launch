    <param name="planner_guide_path_topic" value="$(arg guide_path_topic)"/>
    <param name="frame_id" value="$(arg frame_id)"/>
    <param name="goal_x" value="$(arg goal_x)"/>
    <param name="goal_y" value="$(arg goal_y)"/>
    <param name="goal_z" value="$(arg goal_z)"/>
    <param name="target_ready" value="$(arg task_a_target_ready)"/>
    <param name="goal_input_topic" value="$(arg task_a_goal_input_topic)"/>
    <param name="goal_input_use_pose_z" value="$(arg task_a_goal_input_use_pose_z)"/>
    <param name="transfer_x" value="$(arg transfer_x)"/>
    <param name="transfer_y" value="$(arg transfer_y)"/>
    <param name="transfer_z" value="$(arg transfer_z)"/>
    <param name="reach_radius" value="$(arg task_a_reach_radius)"/>
    <param name="goal_republish_period" value="$(arg task_a_goal_republish_period)"/>
    <param name="takeoff_before_task" value="$(arg task_a_takeoff_before_task)"/>
    <param name="takeoff_height" value="$(arg task_a_takeoff_height)"/>
    <param name="takeoff_reach_radius" value="$(arg task_a_takeoff_reach_radius)"/>
    <param name="require_offboard_before_goal_publish" value="$(arg task_a_require_offboard_before_goal_publish)"/>
    <param name="mavros_state_topic" value="$(arg mavros_state_topic)"/>
    <param name="single_goal_only" value="$(arg single_goal_only)"/>
    <param name="update_task_a_goal_from_guide" value="$(arg task_a_update_goal_from_guide)"/>
    <param name="goal_topic" value="$(arg goal_topic)"/>
  </node>

</launch>
