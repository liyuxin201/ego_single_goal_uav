<?xml version="1.0"?>
<launch>
  <arg name="gui" default="true"/>
  <arg name="start_target_uav" default="false"/>
  <arg name="publish_static_obstacles" default="true"/>
  <arg name="world_name" default="$(find uav_simulator)/worlds/large_pillar/large_pillar_sparse_dynamic.world"/>

  <include file="$(find uav_simulator)/launch/large_pillar_start.launch">
    <arg name="gui" value="$(arg gui)"/>
    <arg name="publish_static_obstacles" value="$(arg publish_static_obstacles)"/>
    <arg name="world_name" value="$(arg world_name)"/>
  </include>

  <include if="$(arg start_target_uav)" file="$(find uav_simulator)/launch/large_pillar_target_uav.launch"/>
</launch>
